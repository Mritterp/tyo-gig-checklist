{
  "name": "production-checklist",
  "version": "1.0.3",
  "description": "Production checklist for film sound recordists",
  "main": "main.js",
  "author": "Production Checklist",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "io.github.mritterp.productionchecklist",
    "productName": "Production Checklist",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "app/**/*",
      "icons/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icons/icon-512.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icons/icon-512.png"
    },
    "publish": {
      "provider": "github",
      "owner": "Mritterp",
      "repo": "tyo-gig-checklist"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
